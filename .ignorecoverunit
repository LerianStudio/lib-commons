# Coverage exclusion patterns for unit tests
# Lines starting with # are comments
# Use * as wildcard for path matching

# Auto-generated mocks
*_mock.go

# Test contract suites — these are test helpers, not production code.
# They define shared contract test suites consumed by integration tests
# against real databases and should not count toward unit coverage.
commons/outbox/outboxtest/


{
  "swagger": "2.0",
  "info": {
    "title": "Systemplane API",
    "description": "Embedded OpenAPI 2.0 specification for systemplane configuration and settings management routes. This spec is bundled with lib-commons because swag init at the consuming application level cannot discover annotations from external Go modules.",
    "version": "v4"
  },
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "tags": [
    {
      "name": "System Configs",
      "description": "Configuration management endpoints"
    },
    {
      "name": "System Settings",
      "description": "Settings management endpoints"
    }
  ],
  "paths": {
    "/v1/system/configs": {
      "get": {
        "operationId": "getSystemConfigs",
        "summary": "Get effective configs",
        "description": "Returns all resolved configuration values with their source and redaction status. Bootstrap-only keys (require restart) are included with their current effective value.",
        "tags": [
          "System Configs"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved configuration values",
            "schema": {
              "$ref": "#/definitions/systemplane.ConfigsResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      },
      "patch": {
        "operationId": "patchSystemConfigs",
        "summary": "Patch config values",
        "description": "Applies a batch of configuration mutations with optimistic concurrency control. Pass the expected revision in the If-Match header (ETag format). A null JSON value for any key resets it to its registered default.",
        "tags": [
          "System Configs"
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          },
          {
            "name": "If-Match",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Expected revision for optimistic concurrency (e.g. \"3\")"
          },
          {
            "name": "request",
            "in": "body",
            "required": true,
            "description": "Configuration values to update",
            "schema": {
              "$ref": "#/definitions/systemplane.PatchConfigsRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New revision after successful write",
            "schema": {
              "$ref": "#/definitions/systemplane.PatchResponse"
            }
          },
          "400": {
            "description": "Invalid request body or empty values",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "409": {
            "description": "Revision conflict",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      }
    },
    "/v1/system/configs/schema": {
      "get": {
        "operationId": "getSystemConfigSchema",
        "summary": "Get config key schema",
        "description": "Returns the registry metadata for all configuration keys, including value type, default value, allowed scopes, mutability, and apply behavior.",
        "tags": [
          "System Configs"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          }
        ],
        "responses": {
          "200": {
            "description": "Schema metadata for all config keys",
            "schema": {
              "$ref": "#/definitions/systemplane.SchemaResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      }
    },
    "/v1/system/configs/history": {
      "get": {
        "operationId": "getSystemConfigHistory",
        "summary": "Get config change history",
        "description": "Returns the change audit trail for configuration entries, ordered by revision. Supports pagination via limit/offset and optional key filtering.",
        "tags": [
          "System Configs"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          },
          {
            "name": "key",
            "in": "query",
            "type": "string",
            "required": false,
            "description": "Filter history by config key"
          },
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 50,
            "minimum": 1,
            "maximum": 100,
            "description": "Maximum number of entries to return"
          },
          {
            "name": "offset",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 0,
            "minimum": 0,
            "description": "Number of entries to skip"
          }
        ],
        "responses": {
          "200": {
            "description": "Configuration change history entries",
            "schema": {
              "$ref": "#/definitions/systemplane.HistoryResponse"
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      }
    },
    "/v1/system/configs/reload": {
      "post": {
        "operationId": "reloadSystemConfigs",
        "summary": "Reload configuration",
        "description": "Triggers a full configuration resynchronization from the backing store. Use after manual database changes or to force a cache refresh.",
        "tags": [
          "System Configs"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          }
        ],
        "responses": {
          "200": {
            "description": "Reload acknowledged",
            "schema": {
              "$ref": "#/definitions/systemplane.ReloadResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Reload failed",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      }
    },
    "/v1/system/settings": {
      "get": {
        "operationId": "getSystemSettings",
        "summary": "Get effective settings",
        "description": "Returns resolved settings for the current scope. The scope defaults to \"tenant\" and can be overridden with ?scope=global. Tenant-scoped settings inherit from global defaults when no tenant override exists.",
        "tags": [
          "System Settings"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          },
          {
            "name": "scope",
            "in": "query",
            "type": "string",
            "required": false,
            "default": "tenant",
            "enum": [
              "tenant",
              "global"
            ],
            "description": "Resolution scope"
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved setting values with scope",
            "schema": {
              "$ref": "#/definitions/systemplane.SettingsResponse"
            }
          },
          "400": {
            "description": "Invalid scope parameter",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      },
      "patch": {
        "operationId": "patchSystemSettings",
        "summary": "Patch setting values",
        "description": "Applies a batch of settings mutations for the resolved scope with optimistic concurrency control. Pass the expected revision in the If-Match header. A null JSON value for any key resets it to its registered default.",
        "tags": [
          "System Settings"
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          },
          {
            "name": "If-Match",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Expected revision for optimistic concurrency (e.g. \"3\")"
          },
          {
            "name": "scope",
            "in": "query",
            "type": "string",
            "required": false,
            "default": "tenant",
            "enum": [
              "tenant",
              "global"
            ],
            "description": "Resolution scope"
          },
          {
            "name": "request",
            "in": "body",
            "required": true,
            "description": "Setting values to update",
            "schema": {
              "$ref": "#/definitions/systemplane.PatchSettingsRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New revision after successful write",
            "schema": {
              "$ref": "#/definitions/systemplane.PatchResponse"
            }
          },
          "400": {
            "description": "Invalid request body or empty values",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "409": {
            "description": "Revision conflict",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      }
    },
    "/v1/system/settings/schema": {
      "get": {
        "operationId": "getSystemSettingSchema",
        "summary": "Get setting key schema",
        "description": "Returns the registry metadata for all setting keys, including value type, default value, allowed scopes, mutability, and apply behavior.",
        "tags": [
          "System Settings"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          }
        ],
        "responses": {
          "200": {
            "description": "Schema metadata for all setting keys",
            "schema": {
              "$ref": "#/definitions/systemplane.SchemaResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      }
    },
    "/v1/system/settings/history": {
      "get": {
        "operationId": "getSystemSettingHistory",
        "summary": "Get setting change history",
        "description": "Returns the change audit trail for settings entries, ordered by revision. The subject is resolved from the auth context (tenant isolation enforcement). Supports pagination via limit/offset and optional key filtering.",
        "tags": [
          "System Settings"
        ],
        "produces": [
          "application/json"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-Request-Id",
            "in": "header",
            "type": "string",
            "required": false,
            "description": "Request ID for tracing"
          },
          {
            "name": "key",
            "in": "query",
            "type": "string",
            "required": false,
            "description": "Filter history by setting key"
          },
          {
            "name": "scope",
            "in": "query",
            "type": "string",
            "required": false,
            "default": "tenant",
            "enum": [
              "tenant",
              "global"
            ],
            "description": "Resolution scope"
          },
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 50,
            "minimum": 1,
            "maximum": 100,
            "description": "Maximum number of entries to return"
          },
          {
            "name": "offset",
            "in": "query",
            "type": "integer",
            "required": false,
            "default": 0,
            "minimum": 0,
            "description": "Number of entries to skip"
          }
        ],
        "responses": {
          "200": {
            "description": "Setting change history entries",
            "schema": {
              "$ref": "#/definitions/systemplane.HistoryResponse"
            }
          },
          "400": {
            "description": "Invalid query parameters or scope",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "403": {
            "description": "Forbidden",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/systemplane.ErrorResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "systemplane.ConfigsResponse": {
      "type": "object",
      "properties": {
        "values": {
          "type": "object",
          "description": "Map of config key to its effective value",
          "additionalProperties": {
            "$ref": "#/definitions/systemplane.EffectiveValueDTO"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "description": "Current snapshot revision"
        }
      }
    },
    "systemplane.EffectiveValueDTO": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "Configuration or setting key name"
        },
        "value": {
          "description": "Current effective value (may be redacted)"
        },
        "default": {
          "description": "Registered default value"
        },
        "source": {
          "type": "string",
          "description": "Where the effective value comes from (e.g. default, override, env)"
        },
        "redacted": {
          "type": "boolean",
          "description": "Whether the value has been redacted for security"
        }
      }
    },
    "systemplane.PatchConfigsRequest": {
      "type": "object",
      "properties": {
        "values": {
          "type": "object",
          "description": "Map of config key to new value. A null value resets the key to its default.",
          "additionalProperties": {}
        }
      }
    },
    "systemplane.PatchResponse": {
      "type": "object",
      "properties": {
        "revision": {
          "type": "integer",
          "format": "uint64",
          "description": "New revision number after the write"
        }
      }
    },
    "systemplane.SchemaResponse": {
      "type": "object",
      "properties": {
        "keys": {
          "type": "array",
          "description": "List of schema entries for all registered keys",
          "items": {
            "$ref": "#/definitions/systemplane.SchemaEntryDTO"
          }
        }
      }
    },
    "systemplane.SchemaEntryDTO": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "Configuration or setting key name"
        },
        "envVar": {
          "type": "string",
          "description": "Backing environment variable name when applicable"
        },
        "kind": {
          "type": "string",
          "description": "Key kind (config or setting)"
        },
        "allowedScopes": {
          "type": "array",
          "description": "Scopes where this key can be overridden",
          "items": {
            "type": "string"
          }
        },
        "valueType": {
          "type": "string",
          "description": "Expected value type (string, int, bool, duration, etc.)"
        },
        "defaultValue": {
          "description": "Registered default value"
        },
        "mutableAtRuntime": {
          "type": "boolean",
          "description": "Whether the key can be changed without restart"
        },
        "applyBehavior": {
          "type": "string",
          "description": "How changes take effect (immediate, restart, reload)"
        },
        "secret": {
          "type": "boolean",
          "description": "Whether the value is sensitive and should be redacted in responses"
        },
        "redactPolicy": {
          "type": "string",
          "description": "Effective redaction policy exposed by the schema"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the key"
        },
        "group": {
          "type": "string",
          "description": "Logical group for UI organization"
        }
      }
    },
    "systemplane.HistoryResponse": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "description": "List of change history entries",
          "items": {
            "$ref": "#/definitions/systemplane.HistoryEntryDTO"
          }
        }
      }
    },
    "systemplane.HistoryEntryDTO": {
      "type": "object",
      "properties": {
        "revision": {
          "type": "integer",
          "format": "uint64",
          "description": "Revision number when the change was made"
        },
        "key": {
          "type": "string",
          "description": "The configuration or setting key that was changed"
        },
        "scope": {
          "type": "string",
          "description": "Scope of the change (global or tenant)"
        },
        "subjectId": {
          "type": "string",
          "description": "Subject identifier (e.g. tenant ID for tenant-scoped changes)"
        },
        "oldValue": {
          "description": "Value before the change"
        },
        "newValue": {
          "description": "Value after the change"
        },
        "actorId": {
          "type": "string",
          "description": "Identifier of the actor who made the change"
        },
        "changedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the change in RFC3339 format"
        }
      }
    },
    "systemplane.SettingsResponse": {
      "type": "object",
      "properties": {
        "values": {
          "type": "object",
          "description": "Map of setting key to its effective value",
          "additionalProperties": {
            "$ref": "#/definitions/systemplane.EffectiveValueDTO"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "description": "Current snapshot revision"
        },
        "scope": {
          "type": "string",
          "description": "Resolved scope (tenant or global)"
        }
      }
    },
    "systemplane.PatchSettingsRequest": {
      "type": "object",
      "properties": {
        "values": {
          "type": "object",
          "description": "Map of setting key to new value. A null value resets the key to its default.",
          "additionalProperties": {}
        }
      }
    },
    "systemplane.ErrorResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Machine-readable error code"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message"
        }
      }
    },
    "systemplane.ReloadResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Reload status (e.g. ok)"
        }
      }
    }
  }
}
